# AlohaMini local operation defaults.

PI_USER=pi5
PI_HOST=192.168.0.24

LOCAL_REPO=./
PI_REPO=/home/pi5/lerobot_alohamini

CONDA_INIT_LOCAL=~/miniconda3/etc/profile.d/conda.sh
CONDA_INIT_PI=/home/pi5/miniconda3/etc/profile.d/conda.sh
CONDA_ENV=lerobot_alohamini

ROBOT_MODEL=alohamini2pro
LEADER_ID=so101_leader_bi
ARM_PROFILE=am-leader-6dof

PI_LOG_DIR=/home/pi5/alohamini_logs
PI_HOST_LOG=/home/pi5/alohamini_logs/lekiwi_host.log
LOCAL_TELEOP_LOG=/tmp/alohamini_teleop.log
ALOHAMINI_DATASET_HOME=./datasets/lerobot
ALOHAMINI_CALIBRATION_HOME=~/.cache/huggingface/lerobot/calibration
LOCAL_RECORD_LOG=/tmp/alohamini_record.log
ALOHAMINI_TASK_CAMERA=true
ALOHAMINI_CAMERAS=forward,wrist_right
ALOHAMINI_RECORD_PREVIEW_FPS=8
